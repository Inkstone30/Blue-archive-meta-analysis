# =====================================================
# Python
# =====================================================
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
dist/
*.egg-info/
.eggs/

# 가상환경 (내 컴퓨터에만 있어야 함 - 팀원과 공유 X)
.venv/
venv/
env/

# =====================================================
# 데이터 파일 (용량이 크거나 개인정보 포함 가능)
# =====================================================
data/raw/*
data/processed/*
# 단, .gitkeep은 유지 (빈 폴더 추적용)
!data/raw/.gitkeep
!data/processed/.gitkeep

# =====================================================
# API 키 및 비밀 정보 (절대 올리면 안 됨!)
# =====================================================
.env
.env.local
secrets.json

# =====================================================
# Jupyter Notebook 출력 결과
# =====================================================
.ipynb_checkpoints/
*.ipynb_checkpoints

# =====================================================
# 운영체제 파일
# =====================================================
# Windows
Thumbs.db
desktop.ini
# macOS
.DS_Store

# =====================================================
# IDE / 에디터
# =====================================================
.vscode/settings.json
.idea/
*.swp

# Claude Code 로컬 설정 (머신마다 달라지는 권한 설정)
.claude/

# =====================================================
# 보고서 출력물 (재생성 가능하므로 제외)
# =====================================================
reports/*.pdf
reports/*.html
reports/*.png
!reports/.gitkeep
